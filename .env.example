# ───────────────────────────────────────────────────────────────
# Northlake — environment
# Copy to .env.local and fill in real values.
# The site runs fully WITHOUT any of these in development:
# the enquiry form gracefully logs to the server console instead.
# ───────────────────────────────────────────────────────────────

# ── Email (Resend) ──────────────────────────────────────────────
# Transactional email for the enquiry form.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# Where enquiries are delivered (verified domain recommended)
CONTACT_TO_EMAIL=advisors@northlake.estate
# Verified sender. For quick tests use "Northlake <onboarding@resend.dev>"
CONTACT_FROM_EMAIL=Northlake <onboarding@resend.dev>

# ── Back office (/admin) ────────────────────────────────────────
# REQUIRED to enable /admin. With this unset, the back office is
# disabled entirely — the safe default for production.
# Use a long, unique phrase; it is checked server-side only.
ADMIN_PASSCODE=

# ── Anti-spam (Cloudflare Turnstile, optional) ──────────────────
# Create a widget at https://dash.cloudflare.com → Turnstile.
# With both keys set, the enquiry form renders the widget and the
# API enforces verification. Leave empty to disable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Analytics (optional, privacy-light) ─────────────────────────
# Microsoft Clarity project id (https://clarity.microsoft.com)
NEXT_PUBLIC_CLARITY_ID=
# PostHog (https://posthog.com) — key + host (EU host recommended)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── Error monitoring (optional) ─────────────────────────────────
# Sentry: run `npx @sentry/wizard@latest -i nextjs` and it will use
# this DSN. Not bundled by default to keep the build lean.
SENTRY_DSN=
